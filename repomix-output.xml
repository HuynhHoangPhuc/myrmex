import type { Grade, AssignGradeInput, UpdateGradeInput } from '../types'

// Derive letter grade client-side (mirrors the DB generated column logic)
export function getLetterGrade(n: number): string {
  if (n >= 8.5) return 'A'
  if (n >= 7.0) return 'B'
  if (n >= 5.5) return 'C'
  if (n >= 4.0) return 'D'
  return 'F'
