-- Backfill fact_enrollment from completed/approved enrollments with grades
INSERT INTO analytics.fact_enrollment (enrollment_id, student_id, subject_id, semester_id, status, grade_numeric, grade_letter, enrolled_at, graded_at)
SELECT
    er.id,
    er.student_id,
    er.subject_id,
    er.semester_id,
    er.status,
    g.grade_numeric,
    g.grade_letter,
    er.requested_at,
    g.graded_at
FROM student.enrollment_requests er
LEFT JOIN student.grades g ON g.enrollment_id = er.id
WHERE er.status IN ('completed', 'approved')
ON CONFLICT (enrollment_id) DO NOTHING;

