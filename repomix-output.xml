}

// --- Room queries ---

type CreateRoomParams struct {
	Name     string
	Capacity int32
	Type     string
	Features []string
}

func (q *Queries) CreateRoom(ctx context.Context, p CreateRoomParams) (TimetableRoom, error) {
	row := q.pool.QueryRow(ctx, `
