// --- Schedule queries ---

func (q *Queries) CreateSchedule(ctx context.Context, semesterID pgtype.UUID, name, status string) (TimetableSchedule, error) {
	row := q.pool.QueryRow(ctx, `
		INSERT INTO timetable.schedules (semester_id, name, status)
