  deleted_at: timestamp nullable,
  unique index: (oauth_provider, oauth_subject) where oauth_provider is not null
)

module_registry (
  id: uuid primary key,
  name: string unique,
  version: string,
  grpc_addr: string,
  health_check_url: string,
